# Engram / Engram environment

EG_PORT=8080
EG_API_KEY=
EG_REQUIRE_API_KEY=false
EG_LOG_AUTH=false
EG_TELEMETRY=true

# Server Mode
EG_MODE=standard
EG_STORAGE=postgres

# PostgreSQL Settings
EG_PG_HOST=localhost
EG_PG_PORT=5432
EG_PG_DB=engram
EG_PG_USER=postgres
EG_PG_PASSWORD=postgres
EG_PG_SCHEMA=public
EG_PG_SSL=disable
EG_PG_POOL_MAX=10
EG_PG_IDLE_TIMEOUT_MS=30000
EG_PG_CONNECTION_TIMEOUT_MS=5000
EG_PG_STATEMENT_TIMEOUT_MS=30000

# Local storage options
EG_SQLITE_PATH=./engram.sqlite
VALKEY_URL=redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Embeddings (Ollama only)
EG_EMBEDDINGS=ollama
EG_EMBEDDING_FALLBACK=ollama
EG_VEC_DIM=1536
EG_EMBED_TIMEOUT_MS=30000
EG_OLLAMA_MODEL=bge-m3

# Ollama (local embeddings & LLM)
OLLAMA_URL=http://localhost:11434
EG_OLLAMA_URL=

# LLM for consolidation / extraction (qwen2.5:3b only)
LLAMA_URL=http://10.10.10.41:8080/v1
EG_LLM_URL=
CONSOLIDATION_MODEL=qwen2.5:3b
EXTRACTION_MODEL=qwen2.5:3b

# Local model path (unused — Ollama manages models)
LOCAL_MODEL_PATH=
EG_LOCAL_MODEL_PATH=

# Vector storage
EG_VECTOR_STORE=postgres
EG_VECTOR_COLLECTION=engram_memories
EG_VECTOR_TIMEOUT_MS=10000
EG_VECTOR_URL=
EG_VECTOR_API_KEY=

# Server limits
EG_MAX_PAYLOAD_SIZE=1000000
EG_RATE_LIMIT_ENABLED=false
EG_RATE_LIMIT_WINDOW_MS=60000
EG_RATE_LIMIT_MAX_REQUESTS=100
