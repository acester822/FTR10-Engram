# Engram environment

# ── Server ──────────────────────────────────────────────────────
EG_PORT=8080
EG_API_KEY=
EG_REQUIRE_API_KEY=false
EG_LOG_AUTH=false
EG_TELEMETRY=true
EG_MODE=standard
EG_MAX_PAYLOAD_SIZE=1000000
EG_RATE_LIMIT_ENABLED=false
EG_RATE_LIMIT_WINDOW_MS=60000
EG_RATE_LIMIT_MAX_REQUESTS=100

# ── Storage backend (postgres | sqlite) ────────────────────────
EG_STORAGE=postgres

# ── PostgreSQL Settings ────────────────────────────────────────
EG_PG_HOST=localhost
EG_PG_PORT=5432
EG_PG_DB=engram
EG_PG_USER=postgres
EG_PG_PASSWORD=postgres
EG_PG_SCHEMA=public
EG_PG_SSL=disable

# ── SQLite path (when EG_STORAGE=sqlite) ───────────────────────
EG_SQLITE_PATH=./engram.sqlite

# ── Embeddings ─────────────────────────────────────────────────
EG_EMBEDDINGS=ollama
EG_EMBEDDING_FALLBACK=ollama
EG_VEC_DIM=1536
EG_EMBED_TIMEOUT_MS=30000

# Override the default embedding model for all providers (unified)
# bge-m3 is the most robust and resource-efficient universal default
EG_EMBED_MODEL=bge-m3

# Per-provider overrides (fallback to defaults below if unset)
EG_OLLAMA_MODEL=

# Per-facet overrides for Ollama (recommended models from model-breakdowns.md)
EG_OLLAMA_EPISODIC_MODEL=bge-m3
EG_OLLAMA_SEMANTIC_MODEL=bge-m3
EG_OLLAMA_PROCEDURAL_MODEL=nomic-embed-text
EG_OLLAMA_EMOTIONAL_MODEL=all-MiniLM-L6-v2
EG_OLLAMA_REFLECTIVE_MODEL=bge-m3

# ── Local Ollama (embeddings only) ─────────────────────────────
EG_OLLAMA_URL=http://localhost:11434

# ── Upstream LLM (request forwarding) ──────────────────────────
# Where Engram forwards enriched requests after memory injection.
EG_UPSTREAM_LLM_URL=http://10.10.10.41:8080/v1

# ── Default model names (not URLs) ─────────────────────────────
EG_CHAT_MODEL=
EG_CONSOLIDATION_MODEL=qwen2.5:14b
EG_EXTRACTION_MODEL=qwen2.5:3b

# ── OpenAI-compatible provider (fallback upstream) ──────────────
EG_OPENAI_API_KEY=
EG_OPENAI_BASE_URL=https://api.openai.com/v1
EG_OPENAI_MODEL=

# ── Gemini / Google AI (fallback upstream) ─────────────────────
EG_GEMINI_API_KEY=

# ── AWS (for S3 / RDS storage backends) ────────────────────────
EG_AWS_REGION=
EG_AWS_ACCESS_KEY_ID=
EG_AWS_SECRET_ACCESS_KEY=

# ── Siray API (fallback upstream) ──────────────────────────────
EG_SIRAY_API_KEY=
EG_SIRAY_API_TOKEN=
EG_SIRAY_BASE_URL=https://api.siray.ai/v1

# ── Vector storage (when EG_VECTOR_STORE is not postgres) ───────
EG_VECTOR_STORE=postgres
EG_VECTOR_COLLECTION=engram_memories
EG_VECTOR_URL=
EG_VECTOR_API_KEY=
EG_VECTOR_TIMEOUT_MS=10000

# ── Local model path (unused — Ollama manages models) ──────────
EG_LOCAL_MODEL_PATH=

# ── Redis / Valkey cache ───────────────────────────────────────
EG_REDIS_URL=redis://localhost:6379

# ── Source frameworks (data ingestion) ─────────────────────────
EG_NOTION_API_KEY=
EG_GOOGLE_CREDENTIALS_JSON=
EG_GOOGLE_SERVICE_ACCOUNT_FILE=
EG_ONEDRIVE_ACCESS_TOKEN=

# ── Release / smoke test (dev only) ────────────────────────────
EG_RELEASE_SMOKE_PORT=18080
EG_RELEASE_SMOKE_FULL=false

# ── Legacy / misc ──────────────────────────────────────────────
EG_OPENMEMORY_API_KEY=
EG_OPENMEMORY_URL=
NODE_ENV=development
EG_HTTP_TIMEOUT_MS=300000
EG_LEGACY_REPORT_INPUT=
EG_LEGACY_REPORT_OUTPUT=
