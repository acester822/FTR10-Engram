# Engram environment
LOG_LEVEL=info
# ===============  Server ======================================================
EG_PORT=8080
EG_API_KEY=
EG_REQUIRE_API_KEY=false
EG_LOG_AUTH=false
EG_TELEMETRY=true
EG_MODE=standard
EG_MAX_PAYLOAD_SIZE=1000000
EG_RATE_LIMIT_ENABLED=false
EG_RATE_LIMIT_WINDOW_MS=60000
EG_RATE_LIMIT_MAX_REQUESTS=100
# =================================================================================

# ===============  Storage =======================================================
EG_STORAGE=postgres
# =================================================================================

# ===============  PostgreSQL Settings ===========================================
EG_PG_HOST=localhost
EG_PG_PORT=5432
EG_PG_DB=engram
EG_PG_USER=postgres
EG_PG_PASSWORD=postgres
EG_PG_SCHEMA=public
EG_PG_SSL=disable
# =================================================================================

# ===============  SQLite path (when EG_STORAGE=sqlite) ==========================
EG_SQLITE_PATH=./engram.sqlite
# =================================================================================

# ===============  Embeddings ====================================================
EG_EMBEDDINGS=ollama
EG_VEC_DIM=768
EG_EMBED_TIMEOUT_MS=30000
# =================================================================================

# ===============  Model Defaults ================================================
# Unified Generative Model (extraction, compaction, consolidation) — MUST be running at all times
EG_GENERATIVE_URL=http://100.108.182.121:8080/v1
EG_MODEL_GENERATIVE=LFM2.5-1.2B-Instruct
EG_MODEL_GENERATIVE_FALLBACK=qwen2.5:3b

# Unified Embedding Model
EG_MODEL_EMBEDDING=qwen3-embedding:0.6b
EG_MODEL_EMBEDDING_FALLBACK=bge-m3
# =================================================================================

# ===============  Compaction Engine =============================================
EG_COMPACT_TRIGGER=100
EG_MAX_RAW_TURNS=4
EG_COMPACT_MAX_MESSAGES=6
EG_COMPACT_PROMPT_MAX_CHARS=800
EG_COMPACT_TIMEOUT_SEC=30
EG_COMPACTION_COOLDOWN_MS=120000
# =================================================================================

# ===============  Memory Extraction ==============================================
EG_EXTRACTION_COOLDOWN_MS=30000
EG_MAX_FACTS_PER_TURN=8
# =================================================================================

# ===============  Ollama (embedding + generative models) ==================
EG_OLLAMA_URL=http://localhost:11434
# =================================================================================

# ===============  Upstream LLM (request forwarding) ==============================
# Where Engram forwards enriched requests after memory injection.
EG_UPSTREAM_LLM_URL=http://100.108.182.121:8080/v1
# =================================================================================

# ===============  OpenAI-compatible provider (fallback upstream) =================
EG_OPENAI_API_KEY=
EG_OPENAI_BASE_URL=https://api.openai.com/v1
EG_OPENAI_MODEL=
# =================================================================================

# ===============  Gemini / Google AI (fallback upstream) =========================
EG_GEMINI_API_KEY=
# =================================================================================

# ===============  AWS (for S3 / RDS storage backends) ============================
EG_AWS_REGION=
EG_AWS_ACCESS_KEY_ID=
EG_AWS_SECRET_ACCESS_KEY=
# =================================================================================

# ===============  Siray API (fallback upstream) ==================================
EG_SIRAY_API_KEY=
EG_SIRAY_API_TOKEN=
EG_SIRAY_BASE_URL=https://api.siray.ai/v1
# =================================================================================

# ===============  Vector storage (when EG_VECTOR_STORE is not postgres) ==========
EG_VECTOR_STORE=postgres
EG_VECTOR_COLLECTION=engram_memories
EG_VECTOR_URL=
EG_VECTOR_API_KEY=
EG_VECTOR_TIMEOUT_MS=10000
# =================================================================================

# ===============  Local model path (unused — Ollama manages models) ==============
EG_LOCAL_MODEL_PATH=
# =================================================================================

# ===============  Redis / Valkey cache ===========================================
EG_REDIS_URL=redis://localhost:6379
# =================================================================================

# ===============  Source frameworks (data ingestion) =============================
EG_NOTION_API_KEY=
EG_GOOGLE_CREDENTIALS_JSON=
EG_GOOGLE_SERVICE_ACCOUNT_FILE=
EG_ONEDRIVE_ACCESS_TOKEN=
# =================================================================================

# ===============  Release / smoke test (dev only) ================================
EG_RELEASE_SMOKE_PORT=18080
EG_RELEASE_SMOKE_FULL=false
# =================================================================================

# ===============  Legacy / misc ==================================================
EG_OPENMEMORY_API_KEY=
EG_OPENMEMORY_URL=
NODE_ENV=development
EG_HTTP_TIMEOUT_MS=300000
EG_LEGACY_REPORT_INPUT=
EG_LEGACY_REPORT_OUTPUT=
# =================================================================================

# ===============  Langfuse (Docker-only) =========================================
# Langfuse auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
SALT=
# Langfuse admin user (auto-created on first boot)
ADMIN_PASSWORD=changeme
# Langfuse API keys (auto-generated; leave blank for auto-creation)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
# Remote LLM host (Docker networks: IP of the machine hosting llama-swap/Ollama)
REMOTE_LLM_URL=http://100.108.182.121:8080
REMOTE_LLM_API_KEY=
REMOTE_LLM_MODEL=qwen3.5:2b
# Internal API key for Engram ↔ Langfuse communication
EG_INTERNAL_API_KEY=
# MinIO S3 credentials (used inside Docker only)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# =================================================================================
