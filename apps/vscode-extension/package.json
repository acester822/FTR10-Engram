{
    "name": "engram-vscode",
    "displayName": "Engram for VS Code",
    "description": "Cognitive memory system that remembers your coding context across sessions",
    "version": "8.0.0",
    "publisher": "Nullure",
    "engines": {
        "vscode": "^1.104.0"
    },
    "categories": [
        "Machine Learning",
        "Other"
    ],
    "keywords": [
        "AI",
        "Memory",
        "Context",
        "Copilot",
        "Cursor",
        "Claude",
        "LLM"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/acester822/engram"
    },
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "engram.statusBarClick",
                "title": "Engram: Status Bar Menu"
            },
            {
                "command": "engram.queryContext",
                "title": "Engram: Query Context"
            },
            {
                "command": "engram.addToMemory",
                "title": "Engram: Add Selection to Memory"
            },
            {
                "command": "engram.quickNote",
                "title": "Engram: Quick Note"
            },
            {
                "command": "engram.viewPatterns",
                "title": "Engram: View Patterns"
            },
            {
                "command": "engram.toggleTracking",
                "title": "Engram: Toggle Tracking"
            },
            {
                "command": "engram.dashboard",
                "title": "Engram: Dashboard"
            },
            {
                "command": "engram.settings",
                "title": "Engram: Settings"
            },
            {
                "command": "engram.openWebGui",
                "title": "Engram: Open Web GUI"
            }
        ],
        "configuration": {
            "title": "Engram",
            "properties": {
                "engram.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable or disable Engram tracking and features"
                },
                "engram.backendUrl": {
                    "type": "string",
                    "default": "http://localhost:8098",
                    "description": "URL of the Engram backend server (API port 8098)"
                },
                "engram.webGuiUrl": {
                    "type": "string",
                    "default": "",
                    "description": "URL of your Engram Web GUI (e.g. http://192.168.1.50:8099). Leave empty and you'll be prompted the first time you click 'Open Web GUI'."
                },
                "engram.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API key for Engram backend authentication (leave empty if no auth required)"
                },
                "engram.userId": {
                    "type": "string",
                    "default": "",
                    "description": "Custom User ID for Engram (leave empty to auto-generate)"
                },
                "engram.projectName": {
                    "type": "string",
                    "default": "",
                    "description": "Custom Project Name (leave empty to use workspace name)"
                },
                "engram.showToasts": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show toast notifications when Engram saves new memories"
                },
                "engram.showStatusBar": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show the Engram live-activity status bar item"
                }
            }
        },
        "chatParticipants": [
            {
                "id": "engram.cortex",
                "name": "cortex",
                "fullName": "Engram Cortex",
                "description": "Chat with full cognitive memory context (Genome + Phenotype)",
                "isSticky": true
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "pretest": "npm run compile",
        "lint": "eslint src --ext ts",
        "postinstall": "node postinstall.js"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^18.x",
        "@types/vscode": "^1.104.0",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "eslint": "^8.56.0",
        "typescript": "^5.3.0",
        "vscode": "^1.1.37"
    }
}